  "rules": [
    {"priority":1,"category":"Accessibility","severity":"CRITICAL","checks":["Normal text contrast at least 4.5:1","Visible keyboard focus","Accessible names for icon buttons","Logical heading order"],"avoid":["Removing focus rings","Color-only status","Placeholder-only labels"]},
    {"priority":2,"category":"Touch and Interaction","severity":"CRITICAL","checks":["Primary targets at least 44px","At least 8px between touch targets","Immediate press feedback","No hover-only primary action"],"avoid":["Tiny icon targets","Gesture-only critical action","Unlabeled destructive action"]},
    {"priority":3,"category":"Performance","severity":"HIGH","checks":["Image dimensions reserve space","Below-fold media is lazy","Motion uses transform and opacity","Heavy surfaces are route split"],"avoid":["Animating width or height","Unbounded client bundles","Layout shift"]},
    {"priority":4,"category":"Style Selection","severity":"HIGH","checks":["Style matches product type","One icon language","Light and dark are designed together","One primary CTA per view"],"avoid":["Random style mixing","Emoji as interface icons","Decorative blur without purpose"]},
    {"priority":5,"category":"Layout and Responsive","severity":"HIGH","checks":["Mobile-first composition","No horizontal overflow","Consistent breakpoints","Readable line length"],"avoid":["Fixed-width mobile layout","Nested scroll traps","Hidden core content on mobile"]},
    {"priority":6,"category":"Typography and Color","severity":"MEDIUM","checks":["Body text at least 16px on mobile","Semantic color tokens","Tabular figures for metrics","Body line height 1.5 or greater"],"avoid":["Raw hex repeated in components","Body copy below 12px","Gray text on gray surface"]},
    {"priority":7,"category":"Animation","severity":"MEDIUM","checks":["Microinteractions use 150-300ms","Motion communicates state","Reduced-motion is supported","One or two focal animations per view"],"avoid":["Decorative continuous motion","Transitions above 500ms","Motion without cleanup"]},
    {"priority":8,"category":"Forms and Feedback","severity":"MEDIUM","checks":["Persistent labels","Errors beside fields","Loading disables duplicate submit","Recovery action is clear"],"avoid":["Errors only at page top","Silent failure","Placeholder as label"]},
    {"priority":9,"category":"Navigation","severity":"HIGH","checks":["Predictable back behavior","Active location is visible","Deep routes are linkable","Mobile navigation remains focused"],"avoid":["Overloaded navigation","Broken browser back","Hidden primary sections"]},
    {"priority":10,"category":"Data Visualization","severity":"LOW","checks":["Legend and tooltip labels","Accessible color pairs","Text or table fallback","Chart type matches question"],"avoid":["Color-only series","Decorative 3D charts","Pie charts with many slices"]}
